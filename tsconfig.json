{
  "compilerOptions": {
    "target": "ES2020",           // или "ES2015" для более широкой поддержки
    "module": "ES2015",            // оставляем ES-модули
    "strict": true,                // включает все строгие проверки типов
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",            // папка для скомпилированных JS-файлов
    "rootDir": "./src",             // папка с исходниками TypeScript
    "removeComments": true,
    "sourceMap": true               // генерация карт кода для отладки
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}